# Copy to .env.local and fill in values (never commit .env.local)

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/solarpro_crm

# Secret for signing JWT session cookies — use a long random string in production
JWT_SECRET=replace-with-long-random-string

# Public site URL — used in password-reset links and absolute URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Nodemailer) — optional; leave blank to skip sending mail ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- WhatsApp Cloud API (Meta) — optional; leave blank to skip WhatsApp ---
# Long-lived token from Meta Developer App > WhatsApp > API Setup
WHATSAPP_TOKEN=
# Phone number ID from the same API Setup page (not your business phone number)
WHATSAPP_PHONE_ID=
